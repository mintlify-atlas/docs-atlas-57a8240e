  "keyFeatures": [
    "Medallion Architecture (Bronze → Silver → Gold) with Delta Lake",
    "Real-time stream processing with Apache Kafka and Spark Structured Streaming",
    "Dead Letter Queue (DLQ) for fault-tolerant ingestion",
    "Change-driven sync optimization for Neo4j and Pinecone",
    "Multi-model data serving: OLAP (ClickHouse), Graph (Neo4j), Vector (Pinecone)",
    "Production-ready deployment with Docker Compose and Kubernetes",
    "Intelligent change-tracking mechanism to minimize downstream updates",
    "Apache Airflow orchestration for batch ETL pipelines"
  ],
  "publicApiSurface": [
    "collector.craw_api.tmdb - TMDB data collection",
    "ingestion.loader - Data loading and mixing",
    "ingestion.producer - Kafka event publishing",
    "stream_processor.sources - Kafka consumption",
    "stream_processor.processor - Stream transformation logic",
    "stream_processor.sinks - Delta Lake writers",
    "batch_jobs.pipelines.bronze_silver.minio_to_minio - Bronze to Silver transformation",
    "batch_jobs.pipelines.silver_silver.minio_to_clickhouse - Silver to ClickHouse sync",
    "batch_jobs.pipelines.silver_gold.clickhouse_to_neo4j - Graph database sync",
    "batch_jobs.pipelines.silver_gold.clickhouse_to_pinecone - Vector database sync",
    "batch_jobs.io.readers - Data readers for Delta Lake and ClickHouse",
    "batch_jobs.io.writers - Data writers for all target databases",
    "batch_jobs.transforms - Data transformation utilities"
  ]
